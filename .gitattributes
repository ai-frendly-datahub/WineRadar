# Git attributes for consistent line endings and encoding

# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files with UTF-8 encoding
*.py text eol=lf encoding=utf-8
*.md text eol=lf encoding=utf-8
*.txt text eol=lf encoding=utf-8
*.yaml text eol=lf encoding=utf-8
*.yml text eol=lf encoding=utf-8
*.json text eol=lf encoding=utf-8
*.html text eol=lf encoding=utf-8
*.jinja text eol=lf encoding=utf-8
*.jinja2 text eol=lf encoding=utf-8
*.css text eol=lf encoding=utf-8
*.js text eol=lf encoding=utf-8
*.xml text eol=lf encoding=utf-8
*.sql text eol=lf encoding=utf-8
*.sh text eol=lf encoding=utf-8

# Configuration files
*.ini text eol=lf encoding=utf-8
*.cfg text eol=lf encoding=utf-8
*.toml text eol=lf encoding=utf-8
.editorconfig text eol=lf encoding=utf-8
.gitignore text eol=lf encoding=utf-8
.gitattributes text eol=lf encoding=utf-8

# Documentation
README* text eol=lf encoding=utf-8
LICENSE* text eol=lf encoding=utf-8
CHANGELOG* text eol=lf encoding=utf-8

# Binary files (do not modify)
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pkl binary
*.pickle binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
