# WineRadar 환경 변수 설정 예시
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# cp .env.example .env

# ====================================
# 데이터베이스 설정 (선택)
# ====================================
# DuckDB 파일 경로 (기본값: data/wineradar.duckdb)
# DB_PATH=data/wineradar.duckdb

# ====================================
# 리포트 설정 (선택)
# ====================================
# 리포트 출력 디렉토리 (기본값: docs/reports)
# REPORT_DIR=docs/reports

# ====================================
# 로깅 설정 (선택)
# ====================================
# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
# LOG_FILE=logs/wineradar.log

# ====================================
# 알림 설정 (선택)
# ====================================
# Slack 웹훅 URL (에러 알림용)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 이메일 알림 설정 (SMTP)
# EMAIL_ENABLED=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_RECEIVER=recipient@example.com

# ====================================
# 고급 설정 (선택)
# ====================================
# 수집 간격 (시간 단위)
# COLLECTION_INTERVAL=24

# Rate Limit 설정
# REQUESTS_PER_MINUTE=60

# 타임아웃 (초)
# REQUEST_TIMEOUT=30

# 재시도 횟수
# MAX_RETRIES=3
