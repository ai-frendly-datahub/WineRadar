# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.py]
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = 100

# YAML files
[*.{yml,yaml}]
charset = utf-8
indent_style = space
indent_size = 2

# JSON files
[*.json]
charset = utf-8
indent_style = space
indent_size = 2

# Markdown files
[*.md]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# HTML/Jinja2 templates
[*.{html,jinja,jinja2}]
charset = utf-8
indent_style = space
indent_size = 2

# Configuration files
[*.{ini,cfg,toml}]
charset = utf-8
indent_style = space
indent_size = 4

# Text files
[*.txt]
charset = utf-8
