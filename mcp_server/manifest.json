{
  "name": "wineradar",
  "version": "0.1.0",
  "description": "WineRadar 그래프/뷰 조회를 위한 MCP 서버",
  "tools": [
    {
      "name": "wineradar.get_view",
      "description": "그래프에서 특정 view_type, focus_id, 기간을 기준으로 이슈 리스트를 조회",
      "input_schema": {
        "type": "object",
        "properties": {
          "view_type": {
            "type": "string",
            "enum": ["winery", "importer", "wine", "topic", "community"]
          },
          "focus_id": {
            "type": "string"
          },
          "time_window_days": {
            "type": "integer",
            "default": 7
          },
          "limit": {
            "type": "integer",
            "default": 20
          }
        },
        "required": ["view_type"]
      }
    },
    {
      "name": "wineradar.top_entities",
      "description": "특정 기간 동안 가장 많이 언급된 엔티티 조회",
      "input_schema": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "enum": ["winery", "importer", "wine", "topic"]
          },
          "time_window_days": {
            "type": "integer",
            "default": 30
          },
          "limit": {
            "type": "integer",
            "default": 10
          }
        },
        "required": ["entity_type"]
      }
    }
  ]
}
